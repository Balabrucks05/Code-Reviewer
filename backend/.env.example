# Smart Contract Review Platform - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Blockchain Explorer API Keys (for fetching on-chain contract source code)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# AI Provider (required for AI code review feature)
# OPENAI_API_KEY=your_openai_api_key_here

# Server
PORT=3000
NODE_ENV=production
